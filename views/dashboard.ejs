<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - PassPort Inc.</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="container">
        <h1>🛂 PassPort Inc.</h1>
        <h2>Bienvenido, <%= user.email %>!</h2>
        <p>Rol: <strong><%= user.role %></strong></p>

        <% if (useJwt && token) { %>
            <div class="token-box">
                <p><strong>Tu token JWT:</strong></p>
                <code id="token"><%= token %></code>
                <br>
                <button onclick="copyToken()">Copiar token</button>
                </div>
        <% } %>

        <% if (user.role === 'admin') { %>
            <a href="/admin" class="btn-admin">Panel de administración</a>
        <% } %>

        <form method="POST" action="/logout">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn-logout">Cerrar sesión</button>
        </form>
    </div>

    <script>
        function copyToken() {
            const token = document.getElementById('token').innerText;
            navigator.clipboard.writeText(token)
            alert('Token copiado');
        }
        // si tiene jwt, intercepta todos los links para mandar el token en el header
        const token = localStorage.getItem('jwt_token');
        if (token) {
            document.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', function(event) {
                    event.preventDefault();
                    fetch(this.href, {
                        headers: {
                            'Authorization': 'Bearer ' + token
                        }
                    }).then(res => res.text())
                        .then(html => {
                            document.open();
                            document.write(html);
                            document.close();
                        });
                });
            });
        }

    </script>
</body>
</html>
    
